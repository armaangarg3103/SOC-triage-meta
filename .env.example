# SOC Alert Triage — Environment Variables

# Required: Hugging Face API token (injected by OpenEnv evaluator)
HF_TOKEN=your_hugging_face_token_here

# Optional: Keep for local dev with OpenAI directly
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override the default OpenAI endpoint
# API_BASE_URL=https://api.openai.com/v1

# Optional: Override the default model
# MODEL_NAME=gpt-4o-mini

# Used by inference.py to target a deployed environment
# ENV_URL=http://localhost:7860
# ENV_URL=https://YOUR_HF_USERNAME-soc-alert-triage.hf.space
