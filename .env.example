# SOC Alert Triage — Environment Variables

# Required: LLM judge API key (Groq — free tier works)
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the default Groq endpoint
# API_BASE_URL=https://api.groq.com/openai/v1

# Optional: Override the default model
# MODEL_NAME=llama3-8b-8192

# Used by inference.py to target a deployed environment
# ENV_URL=http://localhost:7860
# ENV_URL=https://YOUR_HF_USERNAME-soc-alert-triage.hf.space
